# --- Build Artifacts ---
# Ignore the entire target directory where compiled binaries and build cache reside
/target/

# --- Development Tools & IDEs ---
# JetBrains IDEs (IntelliJ, RustRover)
.idea/
*.iml

# VS Code
.vscode/
# Note: Uncomment the line below if you want to share workspace settings/tasks
# !.vscode/launch.json

# --- Logs & Temporary Files ---
# Log files generated by the application or test suites
*.log
# Backup files created by some editors/plugins
**/*.rs.bk
build.rs.bak

# --- OS Specific Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Profiling & Coverage Reports ---
# If using tools like cargo-tarpaulin or cargo-llvm-cov
tarpaulin-report.html
cargo-timing.json
*.profraw

# --- Environment & Secrets ---
# Never commit sensitive information or local configurations
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
